#!/bin/sh
echo "🔒 Running final security checks before push..."

RANGE="origin/main..HEAD"
if ! git rev-parse --verify origin/main > /dev/null 2>&1; then
  RANGE="HEAD~1..HEAD"
fi

# Check if gitleaks is installed
if command -v gitleaks > /dev/null 2>&1; then
  echo "🔍 Running comprehensive Gitleaks scan on outgoing commits..."
  # Detect secrets in waiting-to-be-pushed commits
  gitleaks detect --verbose --log-opts="$RANGE"
  GITLEAKS_EXIT=$?

  if [ $GITLEAKS_EXIT -ne 0 ]; then
    echo "❌ Gitleaks found secrets in your commits!"
    echo "   Please review and remove secrets before pushing."
    echo "   To skip this check (NOT RECOMMENDED): git push --no-verify"
    exit 1
  fi
  echo "✅ Gitleaks comprehensive scan passed"
else
  echo "⚠️  Gitleaks not installed - skipping comprehensive scan"
  if [ -f "c:\Program Files\winget\winget.exe" ]; then
     echo "   Install with: winget install gitleaks"
  else
     echo "   Install Gitleaks: https://github.com/gitleaks/gitleaks"
  fi
fi

echo "🔍 Running basic secret pattern checks..."
if git diff --name-status --diff-filter=AM "$RANGE" | grep -E "^[AM].*environment\.(ts|prod\.ts)$" > /dev/null 2>&1; then
  echo "❌ ERROR: Attempting to commit environment files!"
  echo "   Files: environment.ts, environment.prod.ts"
  exit 1
fi

if git diff --diff-filter=AM "$RANGE" | grep -E "AIzaSy[0-9A-Za-z_-]{33}" > /dev/null 2>&1; then
  echo "❌ ERROR: Firebase API key detected!"
  exit 1
fi

if git diff --diff-filter=AM "$RANGE" | grep -E "gh[ps]_[0-9A-Za-z]{36}" > /dev/null 2>&1; then
  echo "❌ ERROR: GitHub token detected!"
  exit 1
fi

if git diff --diff-filter=AM "$RANGE" | grep -E "AKIA[0-9A-Z]{16}" > /dev/null 2>&1; then
  echo "❌ ERROR: AWS access key detected!"
  exit 1
fi

if git diff --diff-filter=AM "$RANGE" | grep -E "-----BEGIN (RSA|OPENSSH|EC|DSA) PRIVATE KEY-----" > /dev/null 2>&1; then
  echo "❌ ERROR: Private key detected!"
  exit 1
fi

echo "✅ Security checks passed"

echo "🔍 Running quality checks..."
npm run check

echo "✅ Pre-push checks completed"
